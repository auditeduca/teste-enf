# Copie para .env na raiz do repositório ou em NIFS/.env
# Windows legado: C:\Github\CALENF-NKD\.env

# === Obrigatório para tradução/revisão LLM ===
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# === Opcional ===
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_PAGESPEED_API_KEY=

# Desativa todas as chamadas LLM nos agentes
# NKOS_NO_LLM=1

# Caminho customizado para .env (opcional)
# CALENF_ENV_FILE=/caminho/para/.env
