{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://calculadorasdeenfermagem.com.br/schemas/dataset-envelope.schema.json",
  "title": "NKOS reference-dataset envelope",
  "type": "object",
  "required": ["schema_version", "records"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]+\\.[0-9]+$" },
    "generated_at": { "type": "string" },
    "entity": { "type": "string" },
    "count": { "type": "integer", "minimum": 0 },
    "records": { "type": "array", "minItems": 0 }
  }
}
